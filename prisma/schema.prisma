generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  email     String   @unique
  name      String

  // Context for AI personalization
  roleWork  String?
  projects  String?

  // Language preference: "en" | "es"
  preferredLanguage String @default("en")

  // Subscription
  subscriptionStatus String   @default("free")
  stripeCustomerId   String?

  // Rate limiting — task breakdowns
  taskBreakdownsToday Int      @default(0)
  lastBreakdownReset  DateTime @default(now())

  // Rate limiting — clarify requests
  clarifyRequestsToday Int     @default(0)
  lastClarifyReset     DateTime @default(now())

  // Progression tracking
  totalTasksCompleted Int       @default(0)
  currentStreak       Int       @default(0)
  lastCompletionDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks        Task[]
  ownedProjects Project[]
  dayPlans     DayPlan[]
}

model Project {
  id          String   @id @default(uuid())
  profileId   String
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  emoji       String   @default("📁")
  color       String   @default("#86EFAC")
  description String?
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]

  @@index([profileId, status])
}

model Task {
  id        String      @id @default(uuid())
  // profileId references UserProfile.id (NOT Supabase auth user ID)
  profileId String
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  originalText  String
  clarification String?

  status String @default("active")

  // Sharing
  shareToken String? @unique
  isShared   Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  steps TaskStep[]

  @@index([profileId, status])
  @@index([projectId, status])
}

model TaskStep {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  text             String
  order            Int
  durationEstimate String?

  completed   Boolean   @default(false)
  completedAt DateTime?

  // User-edited step text (Day Planner customization)
  userEditedText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dayPlanSteps DayPlanStep[]

  @@index([taskId, order])
}

// Day Planner — one plan per user per day
model DayPlan {
  id         String   @id @default(uuid())
  profileId  String
  date       DateTime @db.Date
  dailyWin   String?
  reflection String?
  mood       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile    UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  steps      DayPlanStep[]

  @@unique([profileId, date])
  @@index([profileId, date])
}

// Individual step assigned to a day plan (links to TaskStep)
model DayPlanStep {
  id               String    @id @default(uuid())
  dayPlanId        String
  taskStepId       String
  sortOrder        Int
  timeSpentSeconds Int       @default(0)
  timerStartedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  dayPlan          DayPlan   @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)
  taskStep         TaskStep  @relation(fields: [taskStepId], references: [id], onDelete: Cascade)

  @@index([dayPlanId, sortOrder])
}
