generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  email     String   @unique
  name      String

  // Context for AI personalization
  roleWork  String?
  projects  String?

  // Language preference: "en" | "es"
  preferredLanguage String @default("en")

  // Subscription
  subscriptionStatus String   @default("free")
  stripeCustomerId   String?

  // Rate limiting — task breakdowns
  taskBreakdownsToday Int      @default(0)
  lastBreakdownReset  DateTime @default(now())

  // Rate limiting — clarify requests
  clarifyRequestsToday Int     @default(0)
  lastClarifyReset     DateTime @default(now())

  // Progression tracking
  totalTasksCompleted Int       @default(0)
  currentStreak       Int       @default(0)
  lastCompletionDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]
}

model Task {
  id        String      @id @default(uuid())
  // profileId references UserProfile.id (NOT Supabase auth user ID)
  profileId String
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  originalText  String
  clarification String?

  status String @default("active")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  steps TaskStep[]

  @@index([profileId, status])
}

model TaskStep {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  text             String
  order            Int
  durationEstimate String?

  completed   Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, order])
}
